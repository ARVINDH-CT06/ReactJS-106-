import { useState, useEffect, useContext, createContext, useReducer } from "react";

// ─────────────────────────────────────────────
// 1. CONTEXT API (Global State)
// ─────────────────────────────────────────────
const PharmacyContext = createContext();

const initialMedicines = [
  { id: 1, name: "Paracetamol", category: "Painkiller", price: 10, stock: 5, expiry: "2025-06-01" },
  { id: 2, name: "Amoxicillin", category: "Antibiotic",  price: 45, stock: 80, expiry: "2026-03-15" },
  { id: 3, name: "Cetirizine",  category: "Antiallergic",price: 20, stock: 3,  expiry: "2024-12-01" },
  { id: 4, name: "Metformin",   category: "Diabetes",    price: 30, stock: 60, expiry: "2026-08-20" },
];

function reducer(state, action) {
  switch (action.type) {
    case "ADD":    return [...state, { ...action.payload, id: Date.now() }];
    case "UPDATE": return state.map(m => m.id === action.payload.id ? action.payload : m);
    case "DELETE": return state.filter(m => m.id !== action.payload);
    default:       return state;
  }
}

function PharmacyProvider({ children }) {
  const [medicines, dispatch] = useReducer(reducer, initialMedicines);
  const [cart, setCart] = useState([]);

  const addMedicine    = (med) => dispatch({ type: "ADD",    payload: med });
  const updateMedicine = (med) => dispatch({ type: "UPDATE", payload: med });
  const deleteMedicine = (id)  => dispatch({ type: "DELETE", payload: id });

  const addToCart = (med) => {
    setCart(prev => {
      const found = prev.find(c => c.id === med.id);
      if (found) return prev.map(c => c.id === med.id ? { ...c, qty: c.qty + 1 } : c);
      return [...prev, { ...med, qty: 1 }];
    });
  };
  const removeFromCart = (id) => setCart(prev => prev.filter(c => c.id !== id));
  const clearCart = () => setCart([]);

  return (
    <PharmacyContext.Provider value={{ medicines, addMedicine, updateMedicine, deleteMedicine, cart, addToCart, removeFromCart, clearCart }}>
      {children}
    </PharmacyContext.Provider>
  );
}

// ─────────────────────────────────────────────
// 2. MEDICINE FORM (Add / Edit)
// ─────────────────────────────────────────────
function MedicineForm({ existing, onDone }) {
  const { addMedicine, updateMedicine } = useContext(PharmacyContext);
  const [form, setForm] = useState(existing || { name:"", category:"", price:"", stock:"", expiry:"" });
  const [errors, setErrors] = useState({});

  const validate = () => {
    const e = {};
    if (!form.name.trim())     e.name     = "Name is required";
    if (!form.category.trim()) e.category = "Category is required";
    if (!form.price || form.price <= 0) e.price = "Enter valid price";
    if (!form.stock || form.stock < 0)  e.stock = "Enter valid stock";
    if (!form.expiry)          e.expiry   = "Expiry date required";
    return e;
  };

  const handleSubmit = (e) => {
    e.preventDefault();
    const errs = validate();
    if (Object.keys(errs).length) { setErrors(errs); return; }
    existing ? updateMedicine({ ...form, price: +form.price, stock: +form.stock })
             : addMedicine({ ...form, price: +form.price, stock: +form.stock });
    onDone();
  };

  const field = (key, label, type = "text") => (
    <div style={s.field}>
      <label style={s.label}>{label}</label>
      <input
        style={{ ...s.input, ...(errors[key] ? s.inputErr : {}) }}
        type={type} value={form[key]}
        onChange={ev => setForm(f => ({ ...f, [key]: ev.target.value }))}
        placeholder={label}
      />
      {errors[key] && <span style={s.err}>{errors[key]}</span>}
    </div>
  );

  return (
    <div style={s.overlay}>
      <div style={s.modal}>
        <h2 style={s.modalTitle}>{existing ? "✏️ Edit Medicine" : "➕ Add Medicine"}</h2>
        <form onSubmit={handleSubmit}>
          {field("name",     "Medicine Name")}
          {field("category", "Category")}
          {field("price",    "Price (₹)", "number")}
          {field("stock",    "Stock Qty", "number")}
          {field("expiry",   "Expiry Date", "date")}
          <div style={{ display:"flex", gap:10, marginTop:16 }}>
            <button style={s.btnPrimary} type="submit">Save</button>
            <button style={s.btnGhost}   type="button" onClick={onDone}>Cancel</button>
          </div>
        </form>
      </div>
    </div>
  );
}

// ─────────────────────────────────────────────
// 3. STOCK TABLE (Inventory)
// ─────────────────────────────────────────────
function StockTable({ onEdit }) {
  const { medicines, deleteMedicine, addToCart } = useContext(PharmacyContext);
  const [search, setSearch] = useState("");
  const today = new Date();

  const filtered = medicines.filter(m =>
    m.name.toLowerCase().includes(search.toLowerCase()) ||
    m.category.toLowerCase().includes(search.toLowerCase())
  );

  const isLowStock = (m) => m.stock <= 5;
  const isExpired  = (m) => new Date(m.expiry) < today;
  const isSoonExp  = (m) => {
    const diff = (new Date(m.expiry) - today) / (1000*60*60*24);
    return diff >= 0 && diff <= 30;
  };

  return (
    <div>
      <input style={{ ...s.input, marginBottom:16, width:"100%", boxSizing:"border-box" }}
        placeholder="🔍 Search medicines..." value={search}
        onChange={e => setSearch(e.target.value)} />

      <div style={{ overflowX:"auto" }}>
        <table style={s.table}>
          <thead>
            <tr style={{ background:"#1e293b", color:"#94a3b8" }}>
              {["Name","Category","Price","Stock","Expiry","Status","Actions"].map(h => (
                <th key={h} style={s.th}>{h}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {filtered.map(m => (
              <tr key={m.id} style={{ borderBottom:"1px solid #1e293b" }}>
                <td style={s.td}><strong style={{ color:"#f1f5f9" }}>{m.name}</strong></td>
                <td style={s.td}><span style={s.badge}>{m.category}</span></td>
                <td style={s.td}>₹{m.price}</td>
                <td style={s.td}>
                  <span style={{ color: isLowStock(m) ? "#ef4444" : "#22c55e", fontWeight:700 }}>
                    {m.stock}
                  </span>
                </td>
                <td style={s.td}>{m.expiry}</td>
                <td style={s.td}>
                  {isExpired(m)  && <span style={{ ...s.tag, background:"#ef444433", color:"#ef4444" }}>Expired</span>}
                  {isSoonExp(m)  && <span style={{ ...s.tag, background:"#f9731633", color:"#f97316" }}>Expiring Soon</span>}
                  {isLowStock(m) && !isExpired(m) && <span style={{ ...s.tag, background:"#eab30833", color:"#eab308" }}>Low Stock</span>}
                  {!isExpired(m) && !isSoonExp(m) && !isLowStock(m) && <span style={{ ...s.tag, background:"#22c55e33", color:"#22c55e" }}>OK</span>}
                </td>
                <td style={s.td}>
                  <button style={s.btnSm}         onClick={() => onEdit(m)}>Edit</button>
                  <button style={{ ...s.btnSm, background:"#ef444422", color:"#ef4444" }} onClick={() => deleteMedicine(m.id)}>Del</button>
                  <button style={{ ...s.btnSm, background:"#3b82f622", color:"#3b82f6" }} onClick={() => addToCart(m)}>+Cart</button>
                </td>
              </tr>
            ))}
            {!filtered.length && (
              <tr><td colSpan={7} style={{ ...s.td, textAlign:"center", color:"#64748b" }}>No medicines found</td></tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// ─────────────────────────────────────────────
// 4. BILLING
// ─────────────────────────────────────────────
function Billing() {
  const { cart, removeFromCart, clearCart, medicines, updateMedicine } = useContext(PharmacyContext);
  const [billed, setBilled] = useState(false);
  const total = cart.reduce((s, c) => s + c.price * c.qty, 0);

  const handleBill = () => {
    // Deduct stock
    cart.forEach(c => {
      const med = medicines.find(m => m.id === c.id);
      if (med) updateMedicine({ ...med, stock: Math.max(0, med.stock - c.qty) });
    });
    setBilled(true);
    setTimeout(() => { clearCart(); setBilled(false); }, 2500);
  };

  if (billed) return (
    <div style={{ textAlign:"center", padding:40 }}>
      <div style={{ fontSize:64 }}>✅</div>
      <h2 style={{ color:"#22c55e", marginTop:8 }}>Bill Generated!</h2>
      <p style={{ color:"#94a3b8" }}>Stock updated successfully.</p>
    </div>
  );

  return (
    <div>
      <h2 style={s.sectionTitle}>🧾 Billing</h2>
      {cart.length === 0 ? (
        <p style={{ color:"#64748b" }}>Cart is empty. Add medicines from Inventory.</p>
      ) : (
        <>
          <table style={s.table}>
            <thead>
              <tr style={{ background:"#1e293b", color:"#94a3b8" }}>
                {["Medicine","Price","Qty","Subtotal",""].map(h => <th key={h} style={s.th}>{h}</th>)}
              </tr>
            </thead>
            <tbody>
              {cart.map(c => (
                <tr key={c.id} style={{ borderBottom:"1px solid #1e293b" }}>
                  <td style={s.td}>{c.name}</td>
                  <td style={s.td}>₹{c.price}</td>
                  <td style={s.td}>{c.qty}</td>
                  <td style={s.td}>₹{c.price * c.qty}</td>
                  <td style={s.td}><button style={{ ...s.btnSm, background:"#ef444422", color:"#ef4444" }} onClick={() => removeFromCart(c.id)}>✕</button></td>
                </tr>
              ))}
            </tbody>
          </table>
          <div style={{ marginTop:20, textAlign:"right" }}>
            <p style={{ fontSize:22, fontWeight:700, color:"#f1f5f9" }}>Total: ₹{total}</p>
            <button style={{ ...s.btnPrimary, marginTop:12 }} onClick={handleBill}>Generate Bill</button>
          </div>
        </>
      )}
    </div>
  );
}

// ─────────────────────────────────────────────
// 5. DASHBOARD
// ─────────────────────────────────────────────
function Dashboard() {
  const { medicines, cart } = useContext(PharmacyContext);
  const today = new Date();
  const low    = medicines.filter(m => m.stock <= 5).length;
  const expd   = medicines.filter(m => new Date(m.expiry) < today).length;
  const soon   = medicines.filter(m => { const d=(new Date(m.expiry)-today)/(1000*60*60*24); return d>=0&&d<=30; }).length;
  const total  = medicines.length;

  const Card = ({ icon, label, value, color }) => (
    <div style={{ ...s.card, borderTop:`3px solid ${color}` }}>
      <div style={{ fontSize:32 }}>{icon}</div>
      <div style={{ color:"#94a3b8", fontSize:13, marginTop:4 }}>{label}</div>
      <div style={{ fontSize:28, fontWeight:700, color, marginTop:4 }}>{value}</div>
    </div>
  );

  return (
    <div>
      <h2 style={s.sectionTitle}>📊 Dashboard</h2>
      <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fit,minmax(160px,1fr))", gap:16, marginBottom:32 }}>
        <Card icon="💊" label="Total Medicines" value={total}          color="#3b82f6" />
        <Card icon="⚠️" label="Low Stock"        value={low}            color="#eab308" />
        <Card icon="☠️" label="Expired"           value={expd}           color="#ef4444" />
        <Card icon="⏳" label="Expiring Soon"     value={soon}           color="#f97316" />
        <Card icon="🛒" label="Cart Items"        value={cart.length}    color="#22c55e" />
      </div>

      {/* Alerts */}
      {low > 0 && (
        <div style={s.alert("#eab308")}>
          ⚠️ <strong>{low} medicine(s)</strong> are running low on stock!
        </div>
      )}
      {expd > 0 && (
        <div style={s.alert("#ef4444")}>
          🚨 <strong>{expd} medicine(s)</strong> have expired and should be removed!
        </div>
      )}
      {soon > 0 && (
        <div style={s.alert("#f97316")}>
          ⏳ <strong>{soon} medicine(s)</strong> are expiring within 30 days.
        </div>
      )}

      <h3 style={{ color:"#94a3b8", marginTop:24, marginBottom:12 }}>Recent Inventory</h3>
      <table style={s.table}>
        <thead>
          <tr style={{ background:"#1e293b", color:"#94a3b8" }}>
            {["Name","Category","Stock","Expiry"].map(h=><th key={h} style={s.th}>{h}</th>)}
          </tr>
        </thead>
        <tbody>
          {medicines.slice(0,5).map(m=>(
            <tr key={m.id} style={{ borderBottom:"1px solid #1e293b" }}>
              <td style={s.td}>{m.name}</td>
              <td style={s.td}>{m.category}</td>
              <td style={{ ...s.td, color: m.stock<=5?"#ef4444":"#22c55e", fontWeight:700 }}>{m.stock}</td>
              <td style={s.td}>{m.expiry}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}

// ─────────────────────────────────────────────
// 6. PAGES
// ─────────────────────────────────────────────
function InventoryPage() {
  const { addMedicine } = useContext(PharmacyContext);
  const [showForm, setShowForm] = useState(false);
  const [editing,  setEditing]  = useState(null);

  const openAdd  = ()   => { setEditing(null); setShowForm(true); };
  const openEdit = (m)  => { setEditing(m);    setShowForm(true); };
  const close    = ()   => { setShowForm(false); setEditing(null); };

  return (
    <div>
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:20 }}>
        <h2 style={s.sectionTitle}>📦 Inventory</h2>
        <button style={s.btnPrimary} onClick={openAdd}>+ Add Medicine</button>
      </div>
      <StockTable onEdit={openEdit} />
      {showForm && <MedicineForm existing={editing} onDone={close} />}
    </div>
  );
}

